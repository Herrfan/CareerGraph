# ==============================================
# 数据库配置
# ==============================================
# MySQL 数据库连接地址
# 阿里云部署时，请替换为您的 RDS 地址
SPRING_DATASOURCE_URL=jdbc:mysql://<your-rds-endpoint>:3306/career_agent?useUnicode=true&characterEncoding=utf-8&serverTimezone=Asia/Shanghai&createDatabaseIfNotExist=true

# 数据库用户名
SPRING_DATASOURCE_USERNAME=<your-db-username>

# 数据库密码
SPRING_DATASOURCE_PASSWORD=<your-db-password>

# ==============================================
# Neo4j 图数据库配置
# ==============================================
# 使用已配置的云 Neo4j 服务（保持不变）
SPRING_NEO4J_URI=neo4j+s://f6954adc.databases.neo4j.io
SPRING_NEO4J_AUTHENTICATION_USERNAME=f6954adc
SPRING_NEO4J_AUTHENTICATION_PASSWORD=8tfth2-tkHvvCXqwMQ5OdIxnwfVe-Z4J_zXrlX1SP7Q

# ==============================================
# AI 服务配置
# ==============================================
# OpenAI 兼容 API 配置（使用 Kimi API）
SPRING_AI_OPENAI_API_KEY=sk-pg7I06zOGBZsfsEC9q9YPOtJtGwnR8hHpPdLzUrgVRzPrAkk
SPRING_AI_OPENAI_BASE_URL=https://api.moonshot.cn
SPRING_AI_OPENAI_CHAT_OPTIONS_MODEL=moonshot-v1-8k

# Ollama 配置（本地部署时使用）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ==============================================
# 应用配置
# ==============================================
# 管理员账号配置
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=admin123

# 会话过期时间（天）
APP_AUTH_SESSION_DAYS=30

# 是否在启动时引导图谱
APP_GRAPH_BOOTSTRAP_ON_STARTUP=false

# ==============================================
# 服务器端口配置
# ==============================================
# 端口配置，阿里云会自动分配，保持默认 8080 即可
PORT=8080
